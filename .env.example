# george/.env.example
#
# This repo ships in two modes:
#
#   AGENT-BACKEND mode — runs the full processMessage loop. Cloudflare
#     Container, Mac mini (when colocated), or local dev. Needs all the
#     LLM, DB, and integration keys.
#
#   BRIDGE mode — runs ONLY the iMessage adapter on a Mac. Forwards each
#     incoming iMessage to a remote agent backend via HTTPS. Does NOT need
#     Anthropic, Supabase, Kimi, Apify, or Google Maps keys. Only needs
#     ADMIN_TOKEN (must match the backend's) and BACKEND_RELAY_URL.
#
# The single switch is BACKEND_RELAY_URL. Empty = agent-backend mode.
# Set = bridge mode.
#
# Vars below are tagged:
#   [agent]   only needed on the agent backend
#   [bridge]  only needed on the iMessage bridge (Mac mini)
#   [phone]   only needed on the agent backend when serving Path B (iPhone Shortcuts)
#   [both]    needed everywhere

# ─── LLMs ─────────────────────────────────────────────────────────────

# [agent] Anthropic Claude — sub-agent responses
ANTHROPIC_API_KEY=

# [agent] Model tiers. SMART = the high-stakes reasoning sub-agent (know-things:
# courses/immigration/housing). FAST = orchestrator routing + small talk + the
# light sub-agents. Defaults (src/config.ts): FAST=claude-haiku, SMART=claude-sonnet.
# Override per environment. NOTE: the multi-agent SDK's per-sub-agent model is only
# honored with recognized model ids; local DeepSeek runs effectively single-tier
# off ANTHROPIC_MODEL.
GEORGE_MODEL_FAST=
GEORGE_MODEL_SMART=

# ─── Doubao (豆包 / 火山方舟 Ark) ───
# TWO independent Doubao integrations, both gated on DOUBAO_API_KEY + DOUBAO_MODEL:
#  (1) AGENT tier (src/agent/model-providers.ts): make a doubao-* id the global
#      tier (GEORGE_MODEL_FAST/SMART=<DOUBAO_MODEL>) or assign it per-user from the
#      admin dashboard. That query() routes to Ark's ANTHROPIC-protocol endpoint.
#  (2) FAST PATH (src/agent/doubao-client.ts): the no-tool emotional / 小聊天 replies
#      (greetings, feelings, comfort, vibes) run on Doubao for its Chinese warmth
#      ("情绪价值"). Falls back to the existing lightweight tier on any Doubao error.
# Enable the model in the Ark console (开通) first and use its exact Model ID.
DOUBAO_API_KEY=
# IMPORTANT: the two paths need DIFFERENT Ark endpoints. The agent (1) speaks the
# Anthropic protocol at .../api/coding; the fast path (2) speaks OpenAI at
# .../api/v3. LEAVE THIS UNSET so each path uses its own correct default. Only set
# it if you run just ONE of the two and need a non-default host (setting it forces
# both paths onto that one endpoint, which breaks the other).
DOUBAO_BASE_URL=
# Shared by both paths, so it must be a model id served on whichever endpoint(s)
# you use. e.g. doubao-seed-1.6 (agent) / doubao-seed-2-0-lite-260215 (fast path).
DOUBAO_MODEL=
# Fast-path thinking budget (seed-1.6 family): minimal | low | medium | high.
# 'minimal' keeps the fast path fast. Unset to omit the param entirely.
DOUBAO_REASONING_EFFORT=minimal

# [agent] Kimi / Moonshot AI (lightweight: classify, memory, proactive, scrape)
KIMI_API_KEY=
# Default: https://api.moonshot.cn/v1 (China). Set https://api.moonshot.ai/v1 for international accounts.
KIMI_BASE_URL=

# ─── Supabase ─────────────────────────────────────────────────────────

# [agent] Database. Anon for public reads, service role for server-side writes.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Adapters ─────────────────────────────────────────────────────────

# [agent] WeChat Official Account (服务号). Leave blank if WeChat OA is dormant.
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# [bridge / agent-local] iMessage (native macOS via @photon-ai/imessage-kit).
# Set to "true" to start the iMessage adapter. Requires:
#   - macOS host
#   - iMessage signed in
#   - Full Disk Access granted to the node binary that tsx resolves to
IMESSAGE_ENABLED=false

# [bridge] Path A switch. When set, the iMessage adapter forwards each new
# message to this URL instead of calling processMessage locally. Leave empty
# on the agent backend itself.
#
#   On the Mac mini:   BACKEND_RELAY_URL=https://your-container.workers.dev
#   On the Container:  BACKEND_RELAY_URL=                        (unset)
# Legacy transport only — removed after Spectrum cutover (Task 14).
BACKEND_RELAY_URL=

# ─── iMessage transport (Spectrum migration) ─────────────────────────
# [agent] Transport selector: 'legacy' (self-hosted dual-path, default) or
# 'spectrum' (Photon hosted). A missing value stays on legacy.
TRANSPORT=legacy
# [agent] Spectrum cloud credentials (Photon dashboard). Shared line pool.
# The bare PROJECT_ID / PROJECT_SECRET names that `bun create spectrum-project`
# scaffolds are also accepted as a fallback if the SPECTRUM_* names are unset.
SPECTRUM_PROJECT_ID=
SPECTRUM_PROJECT_SECRET=
# [agent] Find My location client (Phase 2, dedicated mode only) — leave blank
# until a dedicated line provides an iMessage gRPC address + token.
SPECTRUM_IMESSAGE_ADDRESS=
IMESSAGE_TOKEN=

# [agent] Spectrum reliability watchdog. spectrum-ts retries a wedged inbound
# stream internally FOREVER and never throws, so George can go silently DEAF
# while /health still says connected (the recurring incident). When enabled, a
# 60s timer watches the in-process stream health and detects a wedge two ways:
#   A) our reconnect loop has been failing (state error/reconnecting) continuously
#      for SPECTRUM_WATCHDOG_FAIL_SECONDS with no recovery; OR
#   B) the stream is still 'connected' but has received NO inbound for
#      SPECTRUM_WATCHDOG_SILENT_SECONDS (the in-library wedge — the actual
#      incident). This threshold is deliberately LARGE (3h) so a quiet beta night
#      (~2h of no texts at 3am, which is HEALTHY) never restarts; only a genuine
#      multi-hour deaf-out does. Set to 0 to disable signal B.
# On a wedge it logs spectrum_watchdog_restart and process.exit(1) so Railway
# brings up a fresh process with a fresh Spectrum connection (the same recovery as
# a manual `railway redeploy`). DEFAULT-OFF: unset = no timer, no exits, behavior
# identical to today. Turn on only after review.
# Crash-loop guard: if it has already restarted SPECTRUM_WATCHDOG_MAX_RESTARTS
# times within SPECTRUM_WATCHDOG_WINDOW_SECONDS, it STOPS restarting (Photon is
# genuinely down — restarting would crash-loop) and logs spectrum_watchdog_backoff
# while staying up (degraded) for a human to intervene. A successful reconnect
# clears the budget.
SPECTRUM_WATCHDOG_ENABLED=false
SPECTRUM_WATCHDOG_FAIL_SECONDS=300
SPECTRUM_WATCHDOG_SILENT_SECONDS=10800
SPECTRUM_WATCHDOG_MAX_RESTARTS=3
SPECTRUM_WATCHDOG_WINDOW_SECONDS=1800

# ─── Spectrum burst guard (default-OFF) ───────────────────────────────
# Two layers on the Spectrum inbound path, both off unless ENABLED=true:
#   A) abuse cooldown: a sustained flood (avg > BURST_PER_MIN msgs/min for
#      BURST_STRIKES minutes, i.e. >PER_MIN*STRIKES in STRIKES*60s) → COOLDOWN_MS
#      of quiet after one in-voice notice (no LLM cost). NOT a DDoS defense (that
#      is the Cloudflare WAF's job) — this is a cost cap + polite slow-down.
#   B) splitter: a mid-turn follow-up aborts the in-flight turn but REFOLDS its
#      text into the next turn (up to MAX_REFOLDS) so a thought split across
#      several messages is answered once, not "only the latest".
# When ENABLED=false the inbound loop + user-turn save are byte-for-byte today's.
SPECTRUM_BURST_GUARD_ENABLED=false
SPECTRUM_BURST_PER_MIN=30
SPECTRUM_BURST_STRIKES=3
SPECTRUM_COOLDOWN_MS=300000
SPECTRUM_MAX_REFOLDS=3

# ─── Auth tokens (bearer auth on the agent backend's endpoints) ───────

# [both] ADMIN_TOKEN gates /chat, /admin/scrape-*, and the bridge mode's
# outbound POST to the Container. Must match on both bridge AND agent.
ADMIN_TOKEN=

# [phone] ADMIN_TOKEN_PHONE gates the Path B endpoints used by the iPhone
# Shortcuts: /imessage/incoming, /imessage/outgoing, /imessage/outgoing/:id/ack.
# Keep distinct from ADMIN_TOKEN so a compromised Shortcut token only exposes
# the iMessage queue, not the admin or relay surface. Leave empty if you're
# only running Path A (Mac mini bridge) and not the iPhone fallback.
# Legacy transport only — removed after Spectrum cutover (Task 14).
ADMIN_TOKEN_PHONE=

# ─── External services ───────────────────────────────────────────────

# [agent] bia-roommate API base — powers the course tools (recommend_courses →
# /api/courses/recommend, the interest-based fun-class recommender with real
# course numbers). MUST point at a running bia-roommate, or course recs fail
# and george hedges instead of naming courses. Prod: https://www.uscbia.com
BIA_ROOMMATE_API_URL=https://www.uscbia.com

# [agent] Apify — weekly Instagram event scraper (apify/instagram-scraper).
# When unset, the scraper logs 'instagram_unavailable' and returns without erroring.
# Get one at https://console.apify.com/account/integrations
APIFY_TOKEN=

# [agent] Google Maps Platform key. The code currently calls the LEGACY REST
# endpoints, so enable these 3 APIs on the key:
#   - Geocoding API        (location lookup: resolveOrigin / "near")
#   - Distance Matrix API  (travel_time: drive/walk estimates)
#   - Places API           (find_places: /maps/api/place/textsearch/json)
# IMPORTANT: the "Places API" above is the LEGACY one. Google is deprecating it
# for new Cloud projects — if your project only offers "Places API (New)"
# (places.googleapis.com), tell Claude to switch find_places to the New endpoint
# (a small google-maps.ts change). Geocoding + Distance Matrix have no such split.
# Restrict the key to these APIs and IP-restrict to the production egress IP.
GOOGLE_MAPS_API_KEY=

# ─── Real-world search (find_places + WebSearch) ─────────────────────
# [agent] find_places uses GOOGLE_MAPS_API_KEY above. WebSearch is the Anthropic
# server tool, billed via ANTHROPIC_API_KEY — NO extra key needed.
# Both knobs are optional (sane defaults baked in):
#   WEB_SEARCH_DAILY_CAP        per-student/day web-search cap (default 15)
#   WEB_SEARCH_ALLOWED_DOMAINS  comma-separated trusted domains (default: a
#                               curated list incl. usc.edu, reddit, xiaohongshu)
WEB_SEARCH_DAILY_CAP=15
WEB_SEARCH_ALLOWED_DOMAINS=

# ─── Server ──────────────────────────────────────────────────────────

PORT=3001
NODE_ENV=development

# ─── Feature flags ───────────────────────────────────────────────────

# [agent] Proactive event matcher cron + per-student rollout percentage.
PROACTIVE_ENABLED=true
PROACTIVE_ROLLOUT_PCT=10

# [agent] P4 — grounded proactive heartbeat messages. When 'true', heartbeat
# proactive sends must ground in a concrete open thread (a question George asked
# that went unanswered, or a decision the user was mulling) or stay silent, and
# raised threads are ledgered in george_notes to avoid repeats. DEFAULT-OFF:
# unset/anything-but-'true' leaves the heartbeat prompt byte-for-byte unchanged.
# Needs a human voice review before enabling in production.
GROUNDED_PROACTIVE_ENABLED=false

# ─── Scored-conversation eval harness (tests/eval/conversation) ───
#
# On-demand only. The whole suite is describe.skipIf-gated so a plain
# `npx vitest run` (no key / no flag) SKIPS it and spends ZERO Anthropic
# tokens — identical to how heartbeat-quality is skipped without DEEPSEEK_API_KEY.
# Cost is REAL and per-arm-multiplied: an N-scenario A/B is 2N real orchestrator
# turns (Sonnet + tools) plus up to 2*k*N Opus judge calls.
#
# [eval] Master opt-in. The candidate-generation half needs ANTHROPIC_API_KEY
# AND this flag set to 'true' before the real A/B suite runs (two gates so a dev
# who merely has ANTHROPIC_API_KEY set for normal dev doesn't fire a paid eval on
# every test run). Unset/anything-but-'true' -> suite skipped.
GEORGE_EVAL_CONVO_ENABLED=false
# [eval] Judge half opt-in (independent Opus budget). When unset the harness
# still runs the FREE deterministic gate and reports gate pass/fail only, skipping
# all Opus scoring. Set to 'true' to enable the LLM-judge dimensions + pairwise.
GEORGE_EVAL_JUDGE_ENABLED=false
# [eval] Judge model. A REAL, currently-served Anthropic Opus (verified against
# the Claude API reference) — the most-capable tier, stronger than george's sonnet
# tier, called via the REAL Anthropic client (getClaudeClient), NOT the DeepSeek
# /anthropic gateway. Recorded in every report for cross-run comparability. Do not
# set an invented id — a fabricated model would 404 the entire judge half.
JUDGE_MODEL=claude-opus-4-8
# [eval] Repeated judge sampling: draws per (scenario, arm). >=3 so the per-dim
# mean shrinks judge variance and the flip guard can require a real, significant
# effect rather than a single noisy delta. Default 3.
GEORGE_EVAL_JUDGE_K=3
# [eval] Which default-OFF behavior flag the A/B exercises (OFF arm vs ON arm,
# path flags pinned). E.g. GEORGE_NOREPLY_ENABLED, WORLD_STATE_ENABLED,
# GEORGE_RELATIONSHIP_EVAL_ENABLED. Default GEORGE_NOREPLY_ENABLED.
GEORGE_EVAL_FLAG=GEORGE_NOREPLY_ENABLED

# ─── Heartbeat layer (Slice β) ───────────────────────────────────

# [agent] DeepSeek LLM (lightweight memory updates + internal reasoning)
DEEPSEEK_API_KEY=

# [agent] Heartbeat LLM provider selection (deepseek | kimi)
HEARTBEAT_LLM_PROVIDER=deepseek

# [agent] Cloudflare Workers KV namespace (persistent memory store)
KV_NAMESPACE_ID=
KV_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# [agent] Heartbeat scheduler feature flag
HEARTBEAT_ENABLED=true

# [agent] Per-turn long-term memory capture. After each turn, extracts durable
# facts and appends them to the user's profile blocks (safe, de-duped) so George
# remembers same-session instead of waiting for a heartbeat tick. OFF by default;
# independent of HEARTBEAT_ENABLED. PROD PREREQUISITE: the per-user consent_memory
# column (supabase/migrations/20260624_user_heartbeat_config_consent_memory.sql) must
# be applied + onboarding/web must collect the opt-in — writes (and, once any
# memory-write feature is on, profile INJECTION) are gated on consent_memory and FAIL
# CLOSED, so without it George writes/injects nothing.
# Each captured fact must also carry a verbatim student quote (source-grounding).
MEMORY_CAPTURE_ENABLED=false

# [agent] Free-form prose relationship memory (HANA P3). Every ~5 user messages,
# George rewrites a SHORT prose note about his relationship with the user (tone,
# what they're going through, recurring threads) on the SMART model tier, and
# injects it into the system prompt each turn. Stored zero-schema inside the
# george_notes profile block. Fire-and-forget; never slows a reply. OFF by
# default; independent of HEARTBEAT_ENABLED and MEMORY_CAPTURE_ENABLED. Needs a
# human voice review before enabling in production.
GEORGE_RELATIONSHIP_EVAL_ENABLED=false

# [agent] Single-agent mode. Collapses the orchestrator + 3 sub-agents into ONE
# agent that holds all tools + the unified domain prompt, so tool queries resolve
# in one agentic loop instead of orchestrator→dispatch→sub-agent (removes a hop).
# Off (default) keeps the original multi-agent dispatch path unchanged.
SINGLE_AGENT=false

# [agent] Trunk-hybrid mode. Collapses the orchestrator + know-things into ONE
# trunk agent that answers general convo + USC knowledge directly (holding the
# know-things toolset) and dispatches ONLY to two sub-agents — find-people (squad)
# and whats-happening (events). Takes precedence over SINGLE_AGENT. Off (default)
# is byte-for-byte the original multi-agent 3-sub-agent dispatch path. Read as
# `=== 'true'` exactly like SINGLE_AGENT — any other value (unset/'false'/garbage)
# leaves the default path untouched.
GEORGE_TRUNK_HYBRID=false

# [agent] {{NO_REPLY}} output-format control. When ON, George is told (in
# master.md) he may reply with exactly {{NO_REPLY}} to stay silent on pure acks /
# automated texts, and the adapters suppress the send when he does. OFF by default:
# the instruction is stripped from the prompt and any stray token is still removed
# from outgoing text, so behavior is byte-for-byte unchanged. Needs human voice
# review before enabling.
GEORGE_NOREPLY_ENABLED=false

# [agent] Few-shot voice examples (HANA-style character card). When ON, a bank of
# short-burst 学长 example texts (authored in master.md between sentinels) is added
# to the system prompt on every reactive path + the heartbeat. Prose voice rules
# alone under-constrain register, so George drifts to a long, caretaker, help-desk
# voice; few-shot examples anchor brevity + register far more strongly. OFF by
# default → the block is stripped → prompts byte-for-byte unchanged. Voice change
# real users see — dogfood + human-review the examples before enabling.
GEORGE_VOICE_EXAMPLES_ENABLED=false

# [agent] Activity-aware state + delay-context. Injects a small in-voice note
# about George's plausible state from LA time (awake / late-night / asleep /
# in-class / busy) into the system prompt, and — when there was a long gap since
# his last reply — a note so he can naturally own the gap ("just saw this, was
# asleep"). Pure context only: it does NOT add any response delay; George still
# replies fast. Off (default) leaves prompt assembly byte-for-byte unchanged.
GEORGE_ACTIVITY_STATE_ENABLED=false

# [agent] Read-receipt delay (Track 2). When ON with a positive ms value, George
# pauses BEFORE composing a reply, simulating "reading" the message first. This is
# the ONLY sanctioned intentional delay and it is PRE-generation — it never delays
# an already-composed reply. OFF by default (and a 0 / unset / negative ms value
# is a no-op), so flush() is byte-for-byte unchanged when unused.
GEORGE_READRECEIPT_DELAY_ENABLED=false
GEORGE_READRECEIPT_DELAY_MS=0

# [adapter] Pacing & Delivery v1 (HANA-style typing realism). When ON, a reply's
# first bubble is sent INLINE (responsiveness preserved) and bubbles 2..N are
# persisted to the durable `outgoing_bubbles` queue with length-aware send_at
# times, then sent by a ~1s drainer that SURVIVES restarts (today's in-process
# loop drops a mid-burst tail on a deploy/transport restart). A fresh inbound
# cancels a sender's pending bubbles. OFF by default → today's fixed-600ms
# in-process send loop, byte-for-byte unchanged. PREREQUISITE before flipping ON
# in prod: apply the bia-admin migration 20260625000002_outgoing_bubbles.sql.
# (If flipped on before the migration applies, bubble 1 still sends; only the
# scheduled tail fails per-tick — degrades, never crashes.) Spec:
# docs/superpowers/specs/2026-06-22-pacing-delivery-handoff.md.
GEORGE_PACING_ENABLED=false
PACING_DRAIN_INTERVAL_MS=1000
# Typing-sim constants (chars/sec, min/max gap, think-pause) live in
# src/adapters/typing-sim.ts and are well-tuned for v1; per-deploy env overrides
# are a deliberate fast-follow, not wired yet.

# [agent] World Info timed-state (HANA P5). When on, George notices charged
# topics a student raises (visa / finals / homesick / job-hunt), keeps a short
# in-process "sticky note" warm for a few turns, and injects it into the prompt
# so he stays attuned, then lets it cool. Ephemeral per-user Map, NO DB, cleared
# on restart. Tone guidance only — never overrides voice or anti-fabrication.
# OFF by default: when unset the prompt is byte-for-byte unchanged. Needs a human
# voice review before enabling on the live line.
WORLD_STATE_ENABLED=false

# ─── P6 observational memory ─────────────────────────────────────
# [agent] Per-turn observation log layered on the memory stack. Roll out in
# order: observe -> recall -> reflect. All DEFAULT-OFF — when unset the observe /
# recall / reflect paths are never entered and prompt assembly is byte-for-byte
# unchanged. Writes/reads the user_observations table (bia-admin migration
# 20260621130000_p6_user_observations.sql must be applied first).
# GEORGE_OBSERVE_ENABLED=false   # Observer: per-turn extraction writes observations to user_observations
# GEORGE_RECALL_ENABLED=false    # Recall: per-turn semantic retrieval injected into the prompt
# GEORGE_REFLECT_ENABLED=false   # Reflector: heartbeat folds observations into the profile + prunes
# GEORGE_RECALL_TOOL_ENABLED=false  # Phase 5 (post-MVP): expose the deliberate recall_memory agent tool. OFF → tool absent → byte-identical agent behavior. Reuses RECALL_TOP_K/RECALL_MIN_SALIENCE/RECALL_HALF_LIFE_DAYS.
# GEORGE_UPDATE_MEMORY_TOOL_ENABLED=false  # Expose the deliberate update_memory agent tool (the precision counterpart to MEMORY_CAPTURE): George saves ONE durable student fact to the right profile block mid-reply. OFF → tool absent → byte-identical agent behavior. Writes gated on consent_memory (FAIL CLOSED); shares append_to_profile_block dedup with capture (no double-store).
# GEORGE_MEMORY_PROACTIVE_ENABLED=false  # Phase 6 (post-MVP): heartbeat may PROACTIVELY check in on a remembered observation ("how'd that CSCI 270 final go?"). Adds candidate memories to the EXISTING send_proactive_message decision (model still decides; consent/cadence/quiet-hours unchanged). OFF → no extra DB load, prompt byte-identical. Dedup reuses proactive_raised_threads (mem:<id> keys; no migration). ACTIVATION is a behavioral change — operator's deliberate flip.
# RECALL_TOP_K=4                 # max observations injected per turn (also used by recall_memory tool)
# RECALL_MIN_SALIENCE=2          # 1-5; minimum salience to recall/reflect
# MEMORY_PROACTIVE_MIN_SALIENCE=3  # 1-5; min salience for PROACTIVE memory check-ins (higher bar than reactive recall)
# RECALL_HALF_LIFE_DAYS=14       # recency decay half-life in the recall RPC
# REFLECT_PRUNE_DAYS=30          # delete consolidated/low-salience observations older than this

# ─── Slice B onboarding ──────────────────────────────────────────

# [bridge] iMessage phone number for onboarding handshake invites
GEORGE_IMESSAGE_PHONE=+1XXXXXXXXXX

# [agent] Landing page URL base for onboarding profile links
ONBOARDING_PROFILE_URL_BASE=https://uscbia.com/george/profile

# [agent] Public URL base for handshake assets (showcase PNGs + george.vcf).
# Required for Path B attachments: the iPhone Shortcut can't read this host's
# filesystem, so queued attachment paths are rewritten to URLs under this
# base. If unset, Path B handshake messages are sent text-only.
ONBOARDING_ASSET_BASE_URL=https://uscbia.com/onboarding-assets

# [agent] Pending-users GC cron feature flag (daily 03:00 LA)
ONBOARDING_ENABLED=true

# [agent] Throttle window (hours) for re-sending the onboard link to a
# pending-but-greeted user who never finished the profile form. At most one
# link nudge per this many hours per user until they complete. Default 24.
ONBOARDING_RELINK_HOURS=24

# [bridge] Photon SDK verbose logging (may include message contents)
IMESSAGE_SDK_DEBUG=false

# ─── Squad Phase 4 — after-join coordination ─────────────────────────
# [agent] The Squad Coordinator cron (broker web-interest, RSVP reminders,
# drop-out re-ping, auto-complete). OFF by default. Template messages only — no
# LLM, no extra key. Needs the bia-admin Phase 4 migration applied.
SQUAD_COORDINATION_ENABLED=false
SQUAD_COORDINATION_INTERVAL_CRON=*/15 * * * *
SQUAD_REMINDER_WINDOW_HOURS=24
SQUAD_COMPLETION_GRACE_HOURS=12
# Deep-quiet floor (LA hours) applied to messages that bypass the user's own
# quiet hours, so coordination is never sent at 3am.
SQUAD_DEEP_QUIET_START_HOUR_LA=2
SQUAD_DEEP_QUIET_END_HOUR_LA=8

# ─── Track 2 — re-reach evaluator (stalled-candidate nudge) ───────────
# [agent] Re-reach is 100% additive to and separate from the Squad Coordinator
# above. A cron-only evaluator that nudges STALLED squad candidates ("还在想
# 吗?"). OFF by default — when unset the cron block is never registered, so zero
# new cron, zero new queries, zero new sends. Gates the entire index.ts block AND
# reachEvaluator.isEnabled(). Requires a bia-admin migration adding the
# squad_pings.rereached_at dedup column FIRST (George only reads/writes existing
# tables); keep this OFF until that migration ships.
SQUAD_REREACH_EVAL_ENABLED=false
# Cron interval — only read when enabled. Default hourly.
SQUAD_REREACH_EVAL_INTERVAL_CRON=0 * * * *
# Candidacy threshold in hours — only read when enabled. Default 48h, well past
# the coordinator's 24h reminder window so re-reach never races a live reminder.
SQUAD_REREACH_STALE_HOURS=48

# ─── Admin dashboard — crisis radar (PR-3) ───────────────────────────
# [admin] Surfaces students who may be in real distress (self-harm / not-wanting-
# to-live language in their messages or George's emotion observations) on the
# dashboard's 复盘 (Review) tab, for HUMAN follow-up. OFF by default and MUST stay
# off until a crisis-response operating SOP exists (who watches the queue, how
# often, escalation path, off-hours coverage, how to tune false positives). The
# detector is curated + hyperbole-aware (累死了/搞死 etc. do NOT trigger), but it
# is a surfacing aid, never an automated intervention. Set =true only post-SOP.
GEORGE_CRISIS_RADAR_ENABLED=false
