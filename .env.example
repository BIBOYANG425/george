# Anthropic (Claude — sub-agent responses)
ANTHROPIC_API_KEY=

# Kimi / Moonshot AI (lightweight: classify, memory, proactive, scrape)
KIMI_API_KEY=
# Default: https://api.moonshot.cn/v1 (China). Set https://api.moonshot.ai/v1 for international accounts.
KIMI_BASE_URL=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# WeChat Official Account (服务号)
WECHAT_TOKEN=
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# iMessage (native macOS via @photon-ai/imessage-kit)
# Set to "true" to start the iMessage adapter. Requires:
#   - macOS host
#   - iMessage signed in
#   - Full Disk Access granted to the node/tsx binary
IMESSAGE_ENABLED=false

# bia-roommate API (course tools)
BIA_ROOMMATE_API_URL=http://localhost:3000

# Apify (Instagram scraping)
APIFY_TOKEN=

# Server
PORT=3001
NODE_ENV=development

# Feature flags
PROACTIVE_ENABLED=true
PROACTIVE_ROLLOUT_PCT=10
